{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false
  },
  "include": ["src"],
  "exclude": ["src/**/*.js", "src/**/*.jsx", "src/**/*.d.ts", "src/**/*.map"]
}

